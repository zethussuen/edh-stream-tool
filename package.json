{
  "name": "cedh-stream-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "concurrently -k -n vite,server -c cyan,green \"vp dev\" \"tsx watch server/index.ts\"",
    "build": "vp build",
    "start": "NODE_ENV=production node --import tsx server/index.ts",
    "check": "vp check",
    "electron:dev": "vp build && NODE_OPTIONS='--import tsx' electron .",
    "electron:build": "vp build && electron-builder --mac --win"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.1.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite-plus": "^0.1.15"
  },
  "packageManager": "pnpm@10.33.0"
}